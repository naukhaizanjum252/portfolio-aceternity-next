# Copy this file to .env.local — Next.js does not load .env.example.
# Then restart the dev server (npm run dev) after any change.
#
# Set to "true" to use the new portfolio layout (Phthalo green theme, single-page).
# Set to "false" or leave unset to use the original Aceternity layout.
#
# Alternative: force new layout via URL without env: visit /?new_layout=1
NEXT_PUBLIC_NEW_LAYOUT=true
